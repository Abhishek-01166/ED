@{
    ViewData["Title"] = "Main Menu";
}

<h1 class="mb-4">Main Menu</h1>

<div class="row g-3">
    <div class="col-md-4">
        <a asp-controller="Dashboard" asp-action="Index" class="text-decoration-none">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5">Dashboard</h2>
                    <p class="text-muted mb-0">View patient statistics and recent visits.</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-controller="Patient" asp-action="Search" class="text-decoration-none">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5">Patient Search</h2>
                    <p class="text-muted mb-0">Search patients by code, name, phone number, or email.</p>
                </div>
            </div>
        </a>
    </div>
</div>
